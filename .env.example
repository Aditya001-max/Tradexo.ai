# ============================================
# Counterfactual Trade Analysis Engine
# Environment Configuration
# ============================================

# Hugging Face API Token (get from https://huggingface.co/settings/tokens)
HF_API_TOKEN=hf_your_token_here

# Database URL (default: SQLite)
DATABASE_URL=sqlite+aiosqlite:///./trades.db

# Logging
LOG_LEVEL=INFO

# Parallel workers (default: CPU count)
MAX_WORKERS=4

# Server
HOST=0.0.0.0
PORT=8000
